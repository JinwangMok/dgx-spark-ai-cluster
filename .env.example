# DGX Spark Gemma 4 Cluster - Environment Configuration
# Copy this file to .env and fill in the values before running setup.sh

# === Node Configuration (REQUIRED) ===
NODE_A_IP=          # IP address of Node A (where setup.sh runs)
NODE_B_IP=          # IP address of Node B (remote node)
SSH_USER=           # SSH username for Node B (default: current user)

# === HuggingFace (optional — Gemma 4 is Apache 2.0, no token needed) ===
# HF_TOKEN=         # Only needed for gated/private models

# === Model Configuration (optional overrides) ===
# MODEL_ID=google/gemma-4-26B-A4B-it
# VLLM_GPU_MEMORY_UTILIZATION=0.80
# WHISPER_MODEL=large-v3

# === Paths (optional overrides) ===
# MODEL_CACHE_DIR=/data/models
# WHISPER_CACHE_DIR=/data/models/whisper
